# 应用配置
APP_NAME=局域网文件共享系统
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 服务配置
HOST=0.0.0.0
PORT=8088

# 数据库配置 (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./data/share.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/share_db

# Redis配置 (可选)
# REDIS_URL=redis://localhost:6379/0

# 文件存储配置
STORAGE_PATH=./data/storage
UPLOAD_TEMP_PATH=./data/temp
MAX_UPLOAD_SIZE=524288000
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,webp,pdf,txt,md,doc,docx,xls,xlsx,ppt,pptx,zip,rar,7z,mp3,mp4,avi,mov

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
